{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "ignorePatterns": ["node_modules/**", ".astro/**", "dist/**", ".local/**", "**/*.md", "**/*.mdx"],
  "sortImports": true,
  "sortPackageJson": true,
  "sortTailwindcss": {
    "stylesheet": "./src/style.css",
    "functions": ["clsx", "cn"],
    "preserveWhitespace": true
  }
}
