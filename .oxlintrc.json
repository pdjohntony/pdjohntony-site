{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "warn",
    "perf": "warn",
    "style": "warn"
  },
  "rules": {
    "eslint/sort-imports": "off",
    "typescript/prefer-readonly-parameter-types": "off"
  },
  "options": {
    "typeAware": true
  },
  "env": {
    "builtin": true
  }
}
