---
import { SITE_TITLE } from '../consts'
import HeaderLink from './HeaderLink.astro'
import BlueskyIcon from '../assets/icons/bluesky.svg'
import GitHubIcon from '../assets/icons/github.svg'
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <div class="social-links">
      <a href="https://bsky.app/profile/philljohntony.com">
        <span class="sr-only">Follow me on Bluesky</span>
        <BlueskyIcon width={24} height={24} fill="currentColor" />
      </a>
      <a href="https://github.com/pdjohntony">
        <span class="sr-only">Go to my GitHub profile</span>
        <GitHubIcon width={24} height={24} fill="currentColor" />
      </a>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    /* background: white; */
    /* background: var(--background-4); */
    box-shadow: 0 2px 8px rgba(var(--black), 50%);
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  nav a {
    padding: 1em 0.5em;
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
  }
</style>
