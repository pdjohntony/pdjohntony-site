---
import HeaderLink from './header-link.astro'
---

<header
  data-site-header
  class="sticky top-0 z-40 -mx-6 -mt-4 mb-10 px-6 transition-transform duration-300 ease-out before:pointer-events-none before:absolute before:inset-x-0 before:top-0 before:-bottom-8 before:-z-10 before:bg-bg before:opacity-0 before:transition-opacity before:duration-300 before:[mask-image:linear-gradient(to_bottom,black_55%,transparent)] motion-reduce:transition-none sm:-mx-12 sm:px-12 data-[hidden]:-translate-y-full data-[stuck]:before:opacity-100"
>
  <nav class="flex items-baseline gap-6.5 py-4 text-[15px] font-medium">
    <a href="/" class="mr-auto text-base font-extrabold text-accent transition-colors hover:text-accent-hover">
      ~/phill-johntony
    </a>
    <HeaderLink href="/blog">blog</HeaderLink>
    <HeaderLink href="/projects">projects</HeaderLink>
    <HeaderLink href="/about">about</HeaderLink>
    <button
      type="button"
      data-palette-trigger
      title="command palette"
      class="flex cursor-pointer flex-row-reverse items-center gap-2 rounded-lg bg-surface px-2.5 py-1.5 text-[13px] text-faint transition-colors hover:text-accent-hover"
    >
      <span data-palette-kbd class="hidden sm:inline">⌘K</span>
      <span class="sr-only">search</span>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
    </button>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]')

  if (header) {
    const PAGE_TOP = 0
    // Ignore trackpad jitter: the bar only reveals after this much upward travel
    const REVEAL_TRAVEL_PX = 16
    const NO_TRAVEL = 0
    let lastScrollY = globalThis.scrollY
    let upwardTravel = NO_TRAVEL

    const update = () => {
      const { scrollY } = globalThis
      const stuck = header.getBoundingClientRect().top <= PAGE_TOP
      header.toggleAttribute('data-stuck', stuck && scrollY > PAGE_TOP)

      if (scrollY > lastScrollY && stuck) {
        upwardTravel = NO_TRAVEL
        header.dataset.hidden = ''
      } else if (scrollY < lastScrollY) {
        upwardTravel += lastScrollY - scrollY
        if (upwardTravel >= REVEAL_TRAVEL_PX || !stuck) {
          delete header.dataset.hidden
        }
      }
      lastScrollY = scrollY
    }

    globalThis.addEventListener('scroll', update, { passive: true })
    // Keep keyboard-tabbed nav links visible even after a scroll hid the bar
    header.addEventListener('focusin', () => delete header.dataset.hidden)
  }
</script>
