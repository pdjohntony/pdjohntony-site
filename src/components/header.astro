---
import HeaderLink from './header-link.astro'
---

<header>
  <nav class="flex items-baseline gap-6.5 pb-14 text-[15px] font-medium">
    <a href="/" class="mr-auto text-base font-extrabold text-accent transition-colors hover:text-accent-hover">
      ~/phill-johntony
    </a>
    <HeaderLink href="/blog">blog</HeaderLink>
    <HeaderLink href="/projects">projects</HeaderLink>
    <HeaderLink href="/about">about</HeaderLink>
    <button
      type="button"
      data-palette-trigger
      title="command palette"
      class="flex cursor-pointer flex-row-reverse items-center gap-2 rounded-lg bg-surface px-2.5 py-1.5 text-[13px] text-faint transition-colors hover:text-accent-hover"
    >
      <span data-palette-kbd class="hidden sm:inline">⌘K</span>
      <span class="sr-only">search</span>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
    </button>
  </nav>
</header>
