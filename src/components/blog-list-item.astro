---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import FormattedDate from './formatted-date.astro'

export interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
---

<a href={`/blog/${post.id}/`} class="group flex flex-col border-t border-border pt-5.5 pb-6.5">
  <h2
    class="pb-1.5 text-[19px] font-bold transition-colors group-hover:text-accent-hover"
    style={`view-transition-name: post-${post.id}`}
  >
    {post.data.title}
  </h2>
  <p class="pb-2 text-[15px] leading-[1.55] text-muted">{post.data.description}</p>
  <div class="flex gap-4.5 text-[13px] text-faint lowercase">
    <FormattedDate date={post.data.pubDate} />
    {post.data.tags?.map((tag) => <span>{tag}</span>)}
  </div>
  {
    post.data.heroImage && (
      <Image
        src={post.data.heroImage}
        width={1160}
        height={653}
        class="mt-4 aspect-video w-full rounded-[10px] object-cover"
        alt=""
      />
    )
  }
</a>
