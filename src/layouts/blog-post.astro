---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import FormattedDate from '../components/formatted-date.astro'
import BaseLayout from './base-layout.astro'

type Props = CollectionEntry<'blog'>['data'] & {
  minutesRead?: number
}

const { title, description, pubDate, updatedDate, heroImage, tags, minutesRead } = Astro.props
---

<BaseLayout title={title} description={description} image={heroImage}>
  <div
    data-reading-progress
    class="fixed top-0 left-0 z-50 h-0.5 w-full origin-left bg-accent will-change-transform"
    style="transform: scaleX(0)"
    aria-hidden="true"
  ></div>
  <article data-blog-post>
    <header>
      <h1 class="mt-4 mb-4 text-4xl leading-[1.15] font-extrabold tracking-[-0.02em]">{title}</h1>
      <p class="mb-5 text-lg leading-[1.6] text-muted">{description}</p>
      <div class="flex items-baseline gap-4.5 pb-7 text-[13px] text-faint lowercase">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span>
              updated <FormattedDate date={updatedDate} />
            </span>
          )
        }
        {tags?.map((tag) => <a href={`/tags/${tag}/`} class="transition-colors hover:text-accent-hover">{tag}</a>)}
        {minutesRead && <span class="ml-auto">{minutesRead} min read</span>}
      </div>
      {heroImage && <Image width={1160} height={580} src={heroImage} class="mb-10 w-full rounded-[10px]" alt="" />}
    </header>
    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>

<script>
  const progressBar = document.querySelector<HTMLElement>('[data-reading-progress]')
  const article = document.querySelector<HTMLElement>('[data-blog-post]')

  if (progressBar && article) {
    const MIN_PROGRESS = 0
    const MAX_PROGRESS = 1
    const IDLE_FRAME = 0
    let frame = IDLE_FRAME

    const updateProgress = () => {
      const articleEnd = article.offsetTop + article.offsetHeight - globalThis.innerHeight
      let progress = MAX_PROGRESS

      if (articleEnd > MIN_PROGRESS) {
        progress = Math.max(MIN_PROGRESS, Math.min(globalThis.scrollY / articleEnd, MAX_PROGRESS))
      }

      progressBar.style.transform = `scaleX(${progress})`
      frame = IDLE_FRAME
    }

    const requestUpdate = () => {
      if (frame === IDLE_FRAME) {
        frame = globalThis.requestAnimationFrame(updateProgress)
      }
    }

    updateProgress()
    globalThis.addEventListener('scroll', requestUpdate, { passive: true })
    globalThis.addEventListener('resize', requestUpdate)
  }
</script>
