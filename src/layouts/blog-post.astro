---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import FormattedDate from '../components/formatted-date.astro'
import BaseLayout from './base-layout.astro'

type Props = CollectionEntry<'blog'>['data'] & {
  minutesRead?: number
}

const { title, description, pubDate, updatedDate, heroImage, tags, minutesRead } = Astro.props
---

<BaseLayout title={title} description={description} image={heroImage}>
  <div
    data-reading-progress
    class="fixed top-0 left-0 z-50 h-0.5 w-full origin-left bg-accent will-change-transform"
    style="transform: scaleX(0)"
    aria-hidden="true"
  ></div>
  <article data-blog-post>
    <header>
      <h1 class="mt-4 mb-4 text-4xl leading-[1.15] font-extrabold tracking-[-0.02em]">{title}</h1>
      <p class="mb-5 text-lg leading-[1.6] text-muted">{description}</p>
      <div class="flex items-baseline gap-4.5 pb-7 text-[13px] text-faint lowercase">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span>
              updated <FormattedDate date={updatedDate} />
            </span>
          )
        }
        {tags?.map((tag) => <a href={`/tags/${tag}/`} class="transition-colors hover:text-accent-hover">{tag}</a>)}
        {minutesRead && <span class="ml-auto">{minutesRead} min read</span>}
      </div>
      {heroImage && <Image width={1160} height={580} src={heroImage} class="mb-10 w-full rounded-[10px]" alt="" />}
    </header>
    <div
      class="text-[17px] leading-[1.75] text-prose [&_a]:text-accent [&_a:hover]:text-accent-hover [&_blockquote]:my-9 [&_blockquote]:border-l-2 [&_blockquote]:border-border [&_blockquote]:pl-6 [&_blockquote]:text-lg [&_blockquote]:leading-[1.6] [&_blockquote]:text-muted [&_blockquote_p]:mb-2.5 [&_code]:rounded-md [&_code]:bg-code-bg [&_code]:px-1.75 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[15px] [&_code]:text-text [&_figcaption]:pt-2.5 [&_figcaption]:text-center [&_figcaption]:text-[13px] [&_figcaption]:text-faint [&_h2]:mt-13 [&_h2]:mb-4 [&_h2]:text-2xl [&_h2]:font-extrabold [&_h2]:tracking-[-0.01em] [&_h2]:text-text [&_h3]:mt-9 [&_h3]:mb-3.5 [&_h3]:text-[19px] [&_h3]:font-bold [&_h3]:text-text [&_hr]:my-9 [&_hr]:border-border [&_img]:my-9 [&_img]:w-full [&_img]:rounded-[10px] [&_li]:mb-2.5 [&_li]:pl-1.5 [&_ol]:mb-6 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mb-6 [&_pre]:mb-6 [&_pre]:overflow-x-auto [&_pre]:rounded-[10px] [&_pre]:p-4.5 [&_pre]:text-sm [&_pre]:leading-[1.6] [&_pre]:bg-code-bg! [&_pre_code]:rounded-none [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-sm [&_strong]:font-bold [&_strong]:text-text [&_table]:mb-6 [&_table]:w-full [&_table]:border-collapse [&_table]:text-[15px] [&_td]:border-t [&_td]:border-border [&_td]:py-3 [&_td]:pr-3 [&_th]:pb-2.5 [&_th]:pr-3 [&_th]:text-left [&_th]:text-xs [&_th]:font-bold [&_th]:tracking-[0.08em] [&_th]:text-faint [&_th]:uppercase [&_ul]:mb-6 [&_ul]:list-disc [&_ul]:pl-6"
    >
      <slot />
    </div>
  </article>
</BaseLayout>

<script>
  const progressBar = document.querySelector<HTMLElement>('[data-reading-progress]')
  const article = document.querySelector<HTMLElement>('[data-blog-post]')

  if (progressBar && article) {
    const MIN_PROGRESS = 0
    const MAX_PROGRESS = 1
    const IDLE_FRAME = 0
    let frame = IDLE_FRAME

    const updateProgress = () => {
      const articleEnd = article.offsetTop + article.offsetHeight - globalThis.innerHeight
      let progress = MAX_PROGRESS

      if (articleEnd > MIN_PROGRESS) {
        progress = Math.max(MIN_PROGRESS, Math.min(globalThis.scrollY / articleEnd, MAX_PROGRESS))
      }

      progressBar.style.transform = `scaleX(${progress})`
      frame = IDLE_FRAME
    }

    const requestUpdate = () => {
      if (frame === IDLE_FRAME) {
        frame = globalThis.requestAnimationFrame(updateProgress)
      }
    }

    updateProgress()
    globalThis.addEventListener('scroll', requestUpdate, { passive: true })
    globalThis.addEventListener('resize', requestUpdate)
  }
</script>
