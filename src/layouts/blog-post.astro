---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import FormattedDate from '@/components/formatted-date.astro'
import BaseLayout from './base-layout.astro'

type Props = CollectionEntry<'blog'>['data'] & {
  postId: string
  minutesRead?: string
  headings?: MarkdownHeading[]
  newerPost?: CollectionEntry<'blog'>
  olderPost?: CollectionEntry<'blog'>
}

const {
  postId,
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  minutesRead,
  headings = [],
  newerPost,
  olderPost,
} = Astro.props
const HEADING_LEVEL_TWO = 2
const HEADING_LEVEL_THREE = 3
const tableOfContents = headings.filter(({ depth }) => depth === HEADING_LEVEL_TWO || depth === HEADING_LEVEL_THREE)
---

<BaseLayout title={title} description={description} image={heroImage}>
  <div
    class="reading-progress fixed top-0 left-0 z-50 h-0.5 w-full origin-left bg-accent"
    aria-hidden="true"
  ></div>
  <article
    data-lightbox-gallery
    class="mt-4 [&_img]:cursor-zoom-in [&_img:focus-visible]:outline-2 [&_img:focus-visible]:outline-offset-4 [&_img:focus-visible]:outline-accent min-[1280px]:grid min-[1280px]:w-252.5 min-[1280px]:grid-cols-[768px_210px] min-[1280px]:gap-x-8"
  >
    {
      tableOfContents.length > 0 && (
        <nav
          aria-label="Table of contents"
          class="sticky top-6 z-50 col-start-2 row-span-2 row-start-1 hidden max-h-[calc(100vh-1.5rem)] w-52.5 flex-col self-start overflow-y-auto min-[1280px]:flex"
        >
          <p class="mb-2 text-[13px] font-bold text-muted lowercase">on this page</p>
          <ol class="toc-links flex flex-col gap-0.5">
            {tableOfContents.map(({ depth, slug, text }) => (
              <li>
                <a
                  href={`#${slug}`}
                  class:list={[
                    'block py-1.25 text-[13px] leading-[1.4] text-faint transition-colors hover:text-accent-hover',
                    depth === HEADING_LEVEL_THREE && 'pl-3.5',
                  ]}
                >
                  {text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }
    <header class="[view-transition-name:page-intro]">
      <h1
        class="mt-0 mb-4 text-4xl leading-[1.15] font-extrabold tracking-[-0.02em]"
        style={`view-transition-name: post-${postId}`}
      >
        {title}
      </h1>
      <p class="mb-5 text-lg leading-[1.6] text-muted">{description}</p>
      <div class="flex items-baseline gap-4.5 pb-7 text-[13px] text-faint lowercase">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span>
              updated <FormattedDate date={updatedDate} />
            </span>
          )
        }
        {tags?.map((tag) => <a href={`/tags/${tag}/`} class="transition-colors hover:text-accent-hover">{tag}</a>)}
        {minutesRead && <span class="ml-auto">{minutesRead}</span>}
      </div>
      {heroImage && <Image width={1160} src={heroImage} class="mb-10 w-full rounded-[10px]" alt="" />}
    </header>
    <div class="prose max-w-none [view-transition-name:page-body] min-[1280px]:col-start-1">
      <slot />
    </div>
    {
      (newerPost || olderPost) && (
        <nav
          aria-label="More posts"
          class="mt-11 grid grid-cols-2 gap-6 border-t border-border pt-6 min-[1280px]:col-start-1"
        >
          {newerPost && (
            <a href={`/blog/${newerPost.id}/`} class="group col-start-1 flex min-w-0 flex-col gap-1">
              <span class="text-xs tracking-[0.08em] text-faint uppercase">newer</span>
              <span class="flex items-center gap-1.5 text-[15px] font-bold transition-colors group-hover:text-accent-hover">
                <svg
                  class="shrink-0"
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="15 18 9 12 15 6" />
                </svg>
                {newerPost.data.title}
              </span>
            </a>
          )}
          {olderPost && (
            <a
              href={`/blog/${olderPost.id}/`}
              class="group col-start-2 flex min-w-0 flex-col gap-1 text-right"
            >
              <span class="text-xs tracking-[0.08em] text-faint uppercase">older</span>
              <span class="flex items-center justify-end gap-1.5 text-[15px] font-bold transition-colors group-hover:text-accent-hover">
                {olderPost.data.title}
                <svg
                  class="shrink-0"
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="9 18 15 12 9 6" />
                </svg>
              </span>
            </a>
          )}
        </nav>
      )
    }
  </article>
  <dialog
    data-lightbox
    aria-label="Image preview"
    class="m-auto h-dvh max-h-none w-screen max-w-none overflow-hidden bg-transparent p-6 text-text backdrop:bg-bg/95 backdrop:backdrop-blur-sm open:flex open:items-center open:justify-center sm:p-12"
  >
    <form method="dialog">
      <button
        class="absolute top-5 right-6 z-10 -m-2 p-2 text-[13px] font-medium text-muted lowercase transition-colors hover:text-accent-hover focus-visible:text-accent-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent sm:top-7 sm:right-8"
        type="submit"
      >
        close
      </button>
    </form>
    <figure class="pointer-events-none flex max-h-full max-w-full flex-col items-center gap-3">
      <img data-lightbox-image class="max-h-[calc(100dvh-7rem)] max-w-full rounded-[10px] object-contain" alt="" />
      <figcaption data-lightbox-caption class="max-w-[60ch] text-center text-[13px] text-faint"></figcaption>
    </figure>
  </dialog>
</BaseLayout>

<script>
  const initializeImage = (image: HTMLImageElement, openImage: (image: HTMLImageElement) => void) => {
    let label = 'View image full size'
    if (image.alt) {
      label = `View ${image.alt} full size`
    }

    image.tabIndex = 0
    image.setAttribute('role', 'button')
    image.setAttribute('aria-label', label)

    image.addEventListener('click', (event) => {
      event.preventDefault()
      openImage(image)
    })
    image.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') {
        return
      }

      event.preventDefault()
      openImage(image)
    })
  }

  const initializeDialog = (dialog: HTMLDialogElement, preview: HTMLImageElement) => {
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        dialog.close()
      }
    })
    dialog.addEventListener('close', () => {
      document.documentElement.style.removeProperty('overflow')
      preview.removeAttribute('src')
    })
  }

  const setupLightbox = () => {
    const gallery = document.querySelector<HTMLElement>('[data-lightbox-gallery]')
    const dialog = document.querySelector<HTMLDialogElement>('[data-lightbox]')
    const preview = dialog?.querySelector<HTMLImageElement>('[data-lightbox-image]')
    const caption = dialog?.querySelector<HTMLElement>('[data-lightbox-caption]')

    if (!gallery || !dialog || !preview || !caption || dialog.dataset.ready) {
      return
    }

    dialog.dataset.ready = 'true'

    const openImage = (image: HTMLImageElement) => {
      preview.src = image.currentSrc || image.src
      preview.alt = image.alt
      caption.textContent = image.alt
      caption.hidden = !image.alt
      document.documentElement.style.overflow = 'hidden'
      dialog.showModal()
    }

    gallery.querySelectorAll<HTMLImageElement>('img').forEach((image) => initializeImage(image, openImage))
    initializeDialog(dialog, preview)
  }

  const setupCodeBlocks = () => {
    if (!navigator.clipboard) {
      return
    }

    document.querySelectorAll<HTMLElement>('.code-block').forEach((block) => initializeCodeBlock(block))
  }

  const setCopyButtonState = (button: HTMLButtonElement, label: string, state: 'idle' | 'success' | 'error') => {
    button.setAttribute('aria-label', label)
    button.dataset.copyState = state
    button.title = label
  }

  const createCopyButton = (code: Element) => {
    const COPY_RESET_DELAY_MS = 2000
    const button = document.createElement('button')
    button.type = 'button'
    button.className = 'code-copy'
    setCopyButtonState(button, 'Copy code', 'idle')
    button.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(code.textContent ?? '')
        setCopyButtonState(button, 'Code copied', 'success')
      } catch {
        setCopyButtonState(button, 'Copy failed', 'error')
      }
      globalThis.setTimeout(() => setCopyButtonState(button, 'Copy code', 'idle'), COPY_RESET_DELAY_MS)
    })
    return button
  }

  const initializeCodeBlock = (block: HTMLElement) => {
    const code = block.querySelector('code')
    if (!code || block.dataset.copyReady) {
      return
    }

    block.dataset.copyReady = 'true'
    block.append(createCopyButton(code))
  }

  setupLightbox()
  setupCodeBlocks()
  document.addEventListener('astro:page-load', setupLightbox)
  document.addEventListener('astro:page-load', setupCodeBlocks)
</script>

<style>
  @keyframes reading-progress {
    to {
      transform: scaleX(1);
    }
  }

  .reading-progress {
    transform: scaleX(0);
  }

  .toc-links {
    scroll-target-group: auto;
  }

  [data-lightbox] {
    opacity: 0;
    transform: translateY(8px) scale(0.985);
    transition:
      opacity 220ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      display 220ms allow-discrete,
      overlay 220ms allow-discrete;
  }

  [data-lightbox][open] {
    opacity: 1;
    transform: none;
  }

  [data-lightbox]::backdrop {
    opacity: 0;
    transition:
      opacity 220ms ease,
      display 220ms allow-discrete,
      overlay 220ms allow-discrete;
  }

  [data-lightbox][open]::backdrop {
    opacity: 1;
  }

  @starting-style {
    [data-lightbox][open] {
      opacity: 0;
      transform: translateY(8px) scale(0.985);
    }

    [data-lightbox][open]::backdrop {
      opacity: 0;
    }
  }

  @supports (animation-timeline: scroll()) {
    .reading-progress {
      animation: reading-progress auto linear both;
      animation-timeline: scroll(root block);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-lightbox],
    [data-lightbox]::backdrop {
      transition: none;
    }

    [data-lightbox] {
      transform: none;
    }
  }
</style>

<style is:global>
  .prose .code-block {
    position: relative;
    overflow: hidden;
    margin-block: 1.7142857em;
    border-radius: 0.375rem;
    background: var(--color-code-bg);
  }

  .prose .external-link-icon {
    display: inline-flex;
    width: 0.8em;
    height: 0.8em;
    margin-inline-start: 0.2em;
    vertical-align: 0.05em;
  }

  .prose .external-link-icon svg {
    width: 100%;
    height: 100%;
  }

  .prose .code-block > .mermaid-diagram {
    display: block;
    width: 100%;
    min-width: 42rem;
    height: auto;
    padding: 1rem;
  }

  .prose .code-block:has(> .mermaid-diagram) {
    overflow-x: auto;
  }

  .prose .code-block pre {
    margin: 0;
    border-radius: 0;
    background: var(--color-code-bg) !important;
  }

  .prose .code-block figcaption {
    margin: 0;
    padding: 1.125rem 1.125rem 0;
    background: transparent;
    color: var(--color-faint);
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1rem;
    text-align: left;
  }

  .code-copy {
    position: absolute;
    top: 0.25rem;
    right: 0.4rem;
    width: 1.75rem;
    height: 1.75rem;
    border: 0;
    border-radius: 0.25rem;
    background: transparent;
    color: var(--color-faint);
    cursor: pointer;
    transition: color 150ms ease;
  }

  .code-copy::before,
  .code-copy::after {
    position: absolute;
    width: 0.55rem;
    height: 0.65rem;
    border: 1.5px solid currentColor;
    border-radius: 0.125rem;
    content: '';
  }

  .code-copy::before {
    top: 0.65rem;
    left: 0.55rem;
  }

  .code-copy::after {
    top: 0.45rem;
    left: 0.75rem;
    background: var(--color-code-bg);
  }

  .code-copy[data-copy-state='success'] {
    color: var(--color-success);
  }

  .code-copy[data-copy-state='success']::before {
    top: 0.55rem;
    left: 0.55rem;
    width: 0.75rem;
    height: 0.4rem;
    border: 0;
    border-bottom: 1.5px solid currentColor;
    border-left: 1.5px solid currentColor;
    border-radius: 0;
    transform: rotate(-45deg);
  }

  .code-copy[data-copy-state='success']::after {
    display: none;
  }

  .code-copy[data-copy-state='error'] {
    color: var(--color-callout-danger);
  }

  .code-copy[data-copy-state='idle']:hover,
  .code-copy[data-copy-state='idle']:focus-visible {
    color: var(--color-muted);
  }

  .code-copy:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

<style is:inline>
  .toc-links a:target-current {
    color: var(--color-accent);
  }
</style>
