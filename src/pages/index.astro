---
import { getCollection } from 'astro:content'
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts'
import BaseHead from '../components/base-head.astro'
import BlogListItem from '../components/blog-list-item.astro'
import Footer from '../components/footer.astro'
import Header from '../components/header.astro'

const blogPosts = await getCollection('blog')
const posts = blogPosts.toSorted(
  (firstPost, secondPost) => secondPost.data.pubDate.valueOf() - firstPost.data.pubDate.valueOf(),
)
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Phill Johntony</h1>
      <h3>Software Engineer in Ohio</h3>
      <p>
        Welcome to the official <a href="https://astro.build/">Astro</a> blog starter template. This template serves as a
        lightweight, minimally-styled starting point for anyone looking to build a personal website, blog, or portfolio with
        Astro.
      </p>

      <section>
        <ul class="posts">
          {posts.map((post) => <BlogListItem post={post} />)}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
