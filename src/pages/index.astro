---
import BlogListItem from '../components/blog-list-item.astro'
import { SITE_DESCRIPTION } from '../consts'
import BaseLayout from '../layouts/base-layout.astro'
import { getSortedPosts } from '../lib/posts'

const HOME_LIST_START = 0
const HOME_POST_COUNT = 3
const sortedPosts = await getSortedPosts()
const posts = sortedPosts.slice(HOME_LIST_START, HOME_POST_COUNT)
---

<BaseLayout description={SITE_DESCRIPTION}>
  <div class="[view-transition-name:page-intro]">
    <h1 class="mt-4 mb-5 text-[44px] leading-[1.1] font-extrabold tracking-[-0.03em]">
      hey, i'm phill.<br />
      <span id="tagline" class="text-muted">the man with three first names.</span>
    </h1>
    <script is:inline>
      {
        const taglines = [
          'the man with three first names.',
          'yes, those are all first names.',
          'building software to 80% since 2005.',
          'pro at googling error messages.',
          'slowly automating myself out of a job',
          '99 problems and they\'re all DNS.',
          'the law firm (not really). <span class="text-[0.5rem] font-normal tracking-normal italic">get it? phill. john. tony... nevermind...</span>',
        ]
        document.querySelector('#tagline').innerHTML =
          taglines[Math.floor(Math.random() * taglines.length)]
      }
    </script>
    <p class="mb-11 max-w-140 text-[17px] leading-[1.65] text-muted">
      developer. problem solver. pizza maker. ohioan.
    </p>
  </div>
  <section class="flex flex-col [view-transition-name:page-body]">
    {posts.map((post) => <BlogListItem post={post} />)}
    <div class="flex justify-end border-t border-border pt-5">
      <a href="/blog" class="flex items-center gap-1 text-sm text-accent transition-colors hover:text-accent-hover">
        all posts
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
