---
import { type CollectionEntry, render } from 'astro:content'
import BlogPost from '../../layouts/blog-post.astro'
import { getSortedPosts, PAGE_STEP } from '../../lib/posts'

export const getStaticPaths = async () => {
  const posts = await getSortedPosts()
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      newerPost: posts[index - PAGE_STEP],
      olderPost: posts[index + PAGE_STEP],
      post,
    },
  }))
}
interface Props {
  post: CollectionEntry<'blog'>
  newerPost?: CollectionEntry<'blog'>
  olderPost?: CollectionEntry<'blog'>
}

const { post, newerPost, olderPost } = Astro.props
const { Content, headings } = await render(post)

const WORDS_PER_MINUTE = 200
const EMPTY_WORD_COUNT = 0
const MINIMUM_MINUTES = 1
const wordCount = post.body?.split(/\s+/gu).length ?? EMPTY_WORD_COUNT
const minutesRead = Math.max(MINIMUM_MINUTES, Math.round(wordCount / WORDS_PER_MINUTE))
---

<BlogPost
  {...post.data}
  postId={post.id}
  minutesRead={minutesRead}
  headings={headings}
  newerPost={newerPost}
  olderPost={olderPost}
>
  <Content />
</BlogPost>
