---
import { type CollectionEntry, render } from 'astro:content'
import BlogPost from '@/layouts/blog-post.astro'
import { getSortedPosts, PAGE_STEP } from '@/lib/posts'

export const getStaticPaths = async () => {
  const posts = await getSortedPosts()
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      newerPost: posts[index - PAGE_STEP],
      olderPost: posts[index + PAGE_STEP],
      post,
    },
  }))
}
interface Props {
  post: CollectionEntry<'blog'>
  newerPost?: CollectionEntry<'blog'>
  olderPost?: CollectionEntry<'blog'>
}

const { post, newerPost, olderPost } = Astro.props
const { Content, headings, remarkPluginFrontmatter } = await render(post)
---

<BlogPost
  {...post.data}
  postId={post.id}
  minutesRead={remarkPluginFrontmatter.minutesRead}
  headings={headings}
  newerPost={newerPost}
  olderPost={olderPost}
>
  <Content />
</BlogPost>
