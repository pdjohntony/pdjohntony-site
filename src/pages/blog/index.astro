---
import { getCollection } from 'astro:content'
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts'
import BaseHead from '../../components/base-head.astro'
import BlogListItem from '../../components/blog-list-item.astro'
import Footer from '../../components/footer.astro'
import Header from '../../components/header.astro'

export interface Props {
  per_page?: number
}
const DEFAULT_POSTS_PER_PAGE = 5
const { per_page = DEFAULT_POSTS_PER_PAGE } = Astro.props

const blogPosts = await getCollection('blog')
const posts = blogPosts.toSorted(
  (firstPost, secondPost) => secondPost.data.pubDate.valueOf() - firstPost.data.pubDate.valueOf(),
)
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <ul class="posts">
          {posts.map((post) => <BlogListItem post={post} />)}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
