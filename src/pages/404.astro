---
import BaseLayout from '@/layouts/base-layout.astro'
---

<BaseLayout title="404" description="This page could not be found." noindex>
  <section class="max-w-130 py-12 sm:py-20">
    <div class="[view-transition-name:page-intro]">
      <p class="mb-4 text-[13px] text-faint">error 404</p>
      <h1 class="text-[44px] leading-[1.1] font-extrabold tracking-[-0.03em]">this page went missing.</h1>
    </div>

    <div class="[view-transition-name:page-body]">
      <nav aria-label="404 recovery links" class="mt-8 flex items-center gap-6 text-[15px] font-medium">
        <a href="/" class="text-accent transition-colors hover:text-accent-hover">back home</a>
        <a href="/blog" class="text-muted transition-colors hover:text-accent-hover">read the blog</a>
      </nav>
    </div>
  </section>
</BaseLayout>
