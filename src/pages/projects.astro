---
import BaseLayout from '../layouts/base-layout.astro'

const projects = [
  {
    description: 'self-hosted habit tracker. tracks streaks without guilt-tripping you about them.',
    href: 'https://github.com/pdjohntony',
    name: 'tempo',
    tech: 'go · sqlite · htmx',
  },
  {
    description: 'tiny cli for benchmarking http endpoints. like ab, but with output i can actually read.',
    href: 'https://github.com/pdjohntony',
    name: 'yardstick',
    tech: 'rust',
  },
  {
    description: 'hand-wired split keyboard. v1 worked, so obviously it had to be rebuilt from scratch.',
    href: 'https://github.com/pdjohntony',
    name: 'kbd, v2',
    tech: 'qmk · a soldering iron',
  },
  {
    description: "the thing you're looking at. astro, tailwind, and a blog i promise i'll keep up with.",
    href: 'https://github.com/pdjohntony',
    name: 'this site',
    tech: 'astro · tailwind',
  },
]
---

<BaseLayout title="projects" description="Things I build when I should be sleeping.">
  <div class="[view-transition-name:page-intro]">
    <h1 class="mt-4 mb-9 text-[32px] font-extrabold tracking-[-0.02em]">projects</h1>
  </div>
  <div class="grid grid-cols-1 gap-5 [view-transition-name:page-body] sm:grid-cols-2">
    {
      projects.map((project) => (
        <a
          href={project.href}
          class="flex flex-col gap-2.5 rounded-[14px] bg-surface p-6 transition-colors hover:bg-surface-hover"
        >
          <div class="flex items-center justify-between">
            <span class="text-lg font-bold">{project.name}</span>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-accent"
            >
              <path d="M7 17L17 7M8 7h9v9" />
            </svg>
          </div>
          <p class="text-[15px] leading-[1.55] text-muted">{project.description}</p>
          <div class="mt-auto text-[13px] text-faint">{project.tech}</div>
        </a>
      ))
    }
  </div>
</BaseLayout>
